# AWS Configuration
#
# Configure AWS S3 credentials and settings for backup storage.
# 
# IMPORTANT: Keep this file private! Add it to .gitignore.

# AWS Credentials
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"

# AWS S3 Settings
AWS_REGION="us-east-1"                    # AWS region (e.g., us-east-1, eu-west-1)
AWS_S3_BUCKET="your-bucket-name"          # S3 bucket name (e.g., verva-prod)

# Notes:
# - Get AWS credentials from AWS IAM console
# - Ensure the IAM user has S3 write permissions for the bucket
# - The bucket should already exist before running the installer
